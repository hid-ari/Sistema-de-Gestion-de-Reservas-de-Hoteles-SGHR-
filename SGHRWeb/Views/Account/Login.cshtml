@model SGHRWeb.Models.LoginViewModel
@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = null; // Página standalone sin navbar
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar Sesión – SGHR</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        *{box-sizing:border-box;margin:0;padding:0}
        body{background:#0f1117;color:#e8eaf6;font-family:'Inter',sans-serif;min-height:100vh;display:flex;align-items:center;justify-content:center;}
        .auth-bg{position:fixed;inset:0;background:radial-gradient(ellipse at 20% 50%,rgba(108,99,255,.15) 0%,transparent 60%),radial-gradient(ellipse at 80% 20%,rgba(247,201,72,.08) 0%,transparent 50%);pointer-events:none;}
        .auth-card{background:#1a1d2e;border:1px solid rgba(108,99,255,.25);border-radius:20px;padding:2.5rem;width:100%;max-width:420px;position:relative;z-index:1;box-shadow:0 24px 64px rgba(0,0,0,.5);}
        .brand-row{display:flex;align-items:center;gap:.6rem;justify-content:center;margin-bottom:2rem;}
        .brand-icon{width:44px;height:44px;background:linear-gradient(135deg,#6c63ff,#5a52d5);border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.3rem;}
        .brand-text{font-size:1.4rem;font-weight:700;color:#6c63ff;}
        h1{font-size:1.35rem;font-weight:700;text-align:center;margin-bottom:.3rem;}
        .subtitle{text-align:center;color:#8b8fa8;font-size:.875rem;margin-bottom:1.8rem;}
        .form-group{margin-bottom:1.1rem;}
        label{display:block;font-size:.8rem;font-weight:600;color:#8b8fa8;text-transform:uppercase;letter-spacing:.05em;margin-bottom:.4rem;}
        .input-wrap{position:relative;}
        .input-wrap i{position:absolute;left:.9rem;top:50%;transform:translateY(-50%);color:#8b8fa8;font-size:1rem;pointer-events:none;}
        input[type=email],input[type=password],input[type=text]{width:100%;background:#232640;border:1px solid rgba(255,255,255,.1);color:#e8eaf6;border-radius:10px;padding:.7rem .9rem .7rem 2.6rem;font-family:'Inter',sans-serif;font-size:.9rem;transition:border-color .2s,box-shadow .2s;}
        input:focus{outline:none;border-color:#6c63ff;box-shadow:0 0 0 3px rgba(108,99,255,.2);}
        input::placeholder{color:#555a78;}
        .checkbox-row{display:flex;align-items:center;gap:.5rem;margin-bottom:1.4rem;font-size:.875rem;color:#8b8fa8;}
        .checkbox-row input{width:16px;height:16px;accent-color:#6c63ff;}
        .btn-login{width:100%;background:linear-gradient(135deg,#6c63ff,#5a52d5);color:#fff;border:none;border-radius:10px;padding:.75rem;font-size:.95rem;font-weight:600;cursor:pointer;transition:opacity .2s,transform .15s;font-family:'Inter',sans-serif;}
        .btn-login:hover{opacity:.9;transform:translateY(-1px);}
        .divider{display:flex;align-items:center;gap:.75rem;margin:1.3rem 0;color:#555a78;font-size:.8rem;}
        .divider::before,.divider::after{content:'';flex:1;height:1px;background:rgba(255,255,255,.08);}
        .link-row{text-align:center;font-size:.875rem;color:#8b8fa8;}
        .link-row a{color:#6c63ff;text-decoration:none;font-weight:600;}
        .link-row a:hover{text-decoration:underline;}
        .error-box{background:rgba(248,113,113,.1);border:1px solid rgba(248,113,113,.3);color:#f87171;border-radius:10px;padding:.75rem 1rem;margin-bottom:1.2rem;font-size:.875rem;display:flex;gap:.5rem;align-items:flex-start;}
        .field-error{color:#f87171;font-size:.78rem;margin-top:.3rem;}
        .demo-box{background:rgba(247,201,72,.08);border:1px solid rgba(247,201,72,.2);border-radius:10px;padding:.75rem 1rem;margin-bottom:1.3rem;font-size:.8rem;color:#f7c948;}
        .demo-box strong{display:block;margin-bottom:.25rem;font-size:.85rem;}
    </style>
</head>
<body>
<div class="auth-bg"></div>
<div class="auth-card">
    <div class="brand-row">
        <div class="brand-icon">🏨</div>
        <span class="brand-text">SGHR</span>
    </div>
    <h1>Bienvenido de vuelta</h1>
    <p class="subtitle">Ingresa tus credenciales para acceder al sistema</p>

    <!-- Credenciales demo -->
    <div class="demo-box">
        <strong><i class="bi bi-info-circle"></i> Cuenta demo predeterminada</strong>
        Email: <code>admin@sghr.com</code> &nbsp;|&nbsp; Contraseña: <code>Admin123</code>
    </div>

    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey(string.Empty))
    {
        <div class="error-box">
            <i class="bi bi-exclamation-triangle-fill" style="margin-top:.1rem;flex-shrink:0;"></i>
            <span>@ViewData.ModelState[string.Empty]!.Errors.First().ErrorMessage</span>
        </div>
    }

    <form asp-action="Login" method="post">
        @Html.AntiForgeryToken()
        @if (ViewBag.ReturnUrl != null)
        {
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
        }

        <div class="form-group">
            <label asp-for="Email">Correo electrónico</label>
            <div class="input-wrap">
                <i class="bi bi-envelope"></i>
                <input asp-for="Email" type="email" placeholder="correo@ejemplo.com" autocomplete="email" />
            </div>
            <div class="field-error"><span asp-validation-for="Email"></span></div>
        </div>

        <div class="form-group">
            <label asp-for="Password">Contraseña</label>
            <div class="input-wrap">
                <i class="bi bi-lock"></i>
                <input asp-for="Password" type="password" placeholder="••••••••" autocomplete="current-password" id="pwd" />
            </div>
            <div class="field-error"><span asp-validation-for="Password"></span></div>
        </div>

        <div class="checkbox-row">
            <input asp-for="RememberMe" type="checkbox" id="rememberMe" />
            <label for="rememberMe" style="text-transform:none;letter-spacing:0;font-weight:400;font-size:.875rem;color:#8b8fa8;margin:0;">Recordarme por 30 días</label>
        </div>

        <button type="submit" class="btn-login">
            <i class="bi bi-box-arrow-in-right"></i> Iniciar sesión
        </button>
    </form>

    <div class="divider">o</div>
    <div class="link-row">
        ¿No tienes cuenta? <a asp-controller="Account" asp-action="Register">Regístrate gratis</a>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
