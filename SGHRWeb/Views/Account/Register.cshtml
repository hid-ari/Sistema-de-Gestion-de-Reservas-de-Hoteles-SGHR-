@model SGHRWeb.Models.RegisterViewModel
@{
    ViewData["Title"] = "Crear Cuenta";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registrarse – SGHR</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        *{box-sizing:border-box;margin:0;padding:0}
        body{background:#0f1117;color:#e8eaf6;font-family:'Inter',sans-serif;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:2rem 1rem;}
        .auth-bg{position:fixed;inset:0;background:radial-gradient(ellipse at 80% 50%,rgba(108,99,255,.15) 0%,transparent 60%),radial-gradient(ellipse at 20% 80%,rgba(74,222,128,.06) 0%,transparent 50%);pointer-events:none;}
        .auth-card{background:#1a1d2e;border:1px solid rgba(108,99,255,.25);border-radius:20px;padding:2.5rem;width:100%;max-width:480px;position:relative;z-index:1;box-shadow:0 24px 64px rgba(0,0,0,.5);}
        .brand-row{display:flex;align-items:center;gap:.6rem;justify-content:center;margin-bottom:1.5rem;}
        .brand-icon{width:40px;height:40px;background:linear-gradient(135deg,#6c63ff,#5a52d5);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.2rem;}
        .brand-text{font-size:1.3rem;font-weight:700;color:#6c63ff;}
        h1{font-size:1.3rem;font-weight:700;text-align:center;margin-bottom:.25rem;}
        .subtitle{text-align:center;color:#8b8fa8;font-size:.85rem;margin-bottom:1.6rem;}
        .row-2{display:grid;grid-template-columns:1fr 1fr;gap:.85rem;}
        .form-group{margin-bottom:.95rem;}
        label{display:block;font-size:.78rem;font-weight:600;color:#8b8fa8;text-transform:uppercase;letter-spacing:.05em;margin-bottom:.35rem;}
        .input-wrap{position:relative;}
        .input-wrap i{position:absolute;left:.85rem;top:50%;transform:translateY(-50%);color:#8b8fa8;font-size:.95rem;pointer-events:none;}
        input{width:100%;background:#232640;border:1px solid rgba(255,255,255,.1);color:#e8eaf6;border-radius:10px;padding:.65rem .9rem .65rem 2.5rem;font-family:'Inter',sans-serif;font-size:.88rem;transition:border-color .2s,box-shadow .2s;}
        input:focus{outline:none;border-color:#6c63ff;box-shadow:0 0 0 3px rgba(108,99,255,.2);}
        input::placeholder{color:#555a78;}
        .btn-register{width:100%;background:linear-gradient(135deg,#6c63ff,#5a52d5);color:#fff;border:none;border-radius:10px;padding:.72rem;font-size:.93rem;font-weight:600;cursor:pointer;transition:opacity .2s,transform .15s;font-family:'Inter',sans-serif;margin-top:.5rem;}
        .btn-register:hover{opacity:.9;transform:translateY(-1px);}
        .link-row{text-align:center;font-size:.86rem;color:#8b8fa8;margin-top:1.1rem;}
        .link-row a{color:#6c63ff;text-decoration:none;font-weight:600;}
        .link-row a:hover{text-decoration:underline;}
        .field-error{color:#f87171;font-size:.76rem;margin-top:.25rem;}
        .req-list{display:flex;gap:.5rem;flex-wrap:wrap;margin-top:.4rem;}
        .req{font-size:.72rem;padding:.15rem .5rem;border-radius:5px;background:rgba(255,255,255,.06);color:#8b8fa8;}
        .error-box{background:rgba(248,113,113,.1);border:1px solid rgba(248,113,113,.3);color:#f87171;border-radius:10px;padding:.75rem 1rem;margin-bottom:1rem;font-size:.875rem;}
    </style>
</head>
<body>
<div class="auth-bg"></div>
<div class="auth-card">
    <div class="brand-row">
        <div class="brand-icon">🏨</div>
        <span class="brand-text">SGHR</span>
    </div>
    <h1>Crear cuenta</h1>
    <p class="subtitle">Completa el formulario para acceder al sistema hotelero</p>

    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Any()))
    {
        <div class="error-box">
            <div asp-validation-summary="ModelOnly"></div>
        </div>
    }

    <form asp-action="Register" method="post">
        @Html.AntiForgeryToken()

        <div class="row-2">
            <div class="form-group">
                <label asp-for="Nombre">Nombre</label>
                <div class="input-wrap">
                    <i class="bi bi-person"></i>
                    <input asp-for="Nombre" placeholder="Juan" autocomplete="given-name" />
                </div>
                <div class="field-error"><span asp-validation-for="Nombre"></span></div>
            </div>
            <div class="form-group">
                <label asp-for="Apellido">Apellido</label>
                <div class="input-wrap">
                    <i class="bi bi-person"></i>
                    <input asp-for="Apellido" placeholder="Pérez" autocomplete="family-name" />
                </div>
                <div class="field-error"><span asp-validation-for="Apellido"></span></div>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="Email">Correo electrónico</label>
            <div class="input-wrap">
                <i class="bi bi-envelope"></i>
                <input asp-for="Email" type="email" placeholder="correo@ejemplo.com" autocomplete="email" />
            </div>
            <div class="field-error"><span asp-validation-for="Email"></span></div>
        </div>

        <div class="form-group">
            <label asp-for="Telefono">Teléfono</label>
            <div class="input-wrap">
                <i class="bi bi-telephone"></i>
                <input asp-for="Telefono" type="tel" placeholder="8091234567" autocomplete="tel" />
            </div>
            <div class="field-error"><span asp-validation-for="Telefono"></span></div>
        </div>

        <div class="row-2">
            <div class="form-group">
                <label asp-for="Password">Contraseña</label>
                <div class="input-wrap">
                    <i class="bi bi-lock"></i>
                    <input asp-for="Password" type="password" placeholder="••••••••" autocomplete="new-password" />
                </div>
                <div class="field-error"><span asp-validation-for="Password"></span></div>
                <div class="req-list">
                    <span class="req">8+ chars</span>
                    <span class="req">Mayúscula</span>
                    <span class="req">Número</span>
                </div>
            </div>
            <div class="form-group">
                <label asp-for="ConfirmPassword">Confirmar</label>
                <div class="input-wrap">
                    <i class="bi bi-lock-fill"></i>
                    <input asp-for="ConfirmPassword" type="password" placeholder="••••••••" autocomplete="new-password" />
                </div>
                <div class="field-error"><span asp-validation-for="ConfirmPassword"></span></div>
            </div>
        </div>

        <button type="submit" class="btn-register">
            <i class="bi bi-person-check"></i> Crear cuenta
        </button>
    </form>

    <div class="link-row">
        ¿Ya tienes cuenta? <a asp-controller="Account" asp-action="Login">Iniciar sesión</a>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
