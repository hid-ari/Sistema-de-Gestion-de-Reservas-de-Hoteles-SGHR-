@model List<SGHR.Data.Models.CategoriaHabitacion>
@{
    ViewData["Title"] = "Categorías de Habitaciones";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="page-title mb-0"><i class="bi bi-tags me-2" style="color:var(--primary);"></i>Categorías de Habitaciones</h1>
        <p style="color:var(--text-muted);font-size:.875rem;margin-top:.25rem;">SRS §3.3 – Gestión de Categorías</p>
    </div>
    <a asp-action="Create" class="btn-primary-sghr"><i class="bi bi-plus-lg"></i> Nueva Categoría</a>
</div>

@if (!Model.Any())
{
    <div class="sghr-card text-center py-5">
        <div style="font-size:3rem;opacity:.4;">🏷️</div>
        <p style="color:var(--text-muted);margin-top:1rem;">No hay categorías registradas. Crea la primera.</p>
    </div>
}
else
{
    <div class="sghr-card p-0" style="overflow:hidden;">
        <table class="sghr-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Nombre</th>
                    <th>Tarifa / noche</th>
                    <th>Características</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cat in Model)
                {
                    <tr>
                        <td style="color:var(--text-muted);">@cat.Id</td>
                        <td>
                            <div style="font-weight:600;">@cat.Nombre</div>
                            <div style="color:var(--text-muted);font-size:.8rem;">@cat.Descripcion</div>
                        </td>
                        <td style="color:var(--accent);font-weight:700;">$@cat.TarifaPorNoche.ToString("N2")</td>
                        <td style="color:var(--text-muted);font-size:.85rem;">@(string.IsNullOrEmpty(cat.Caracteristicas) ? "—" : cat.Caracteristicas)</td>
                        <td>
                            @if (cat.Activa)
                            {
                                <span class="badge-confirmada">Activa</span>
                            }
                            else
                            {
                                <span class="badge-cancelada">Inactiva</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@cat.Id" class="btn-ghost" style="font-size:.8rem;padding:.3rem .7rem;">
                                    <i class="bi bi-pencil"></i> Editar
                                </a>
                                <form asp-action="Delete" asp-route-id="@cat.Id" method="post" onsubmit="return confirm('¿Eliminar categoría @cat.Nombre?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-danger-sghr" style="font-size:.8rem;">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
