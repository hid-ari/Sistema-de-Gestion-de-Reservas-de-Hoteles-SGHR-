@model SGHR.Data.Models.CategoriaHabitacion
@{
    ViewData["Title"] = "Nueva Categoría";
}

<div class="mb-4">
    <a asp-action="Index" class="btn-ghost"><i class="bi bi-arrow-left"></i> Volver</a>
</div>

<div class="sghr-card" style="max-width:600px;">
    <h1 class="page-title"><i class="bi bi-plus-circle me-2" style="color:var(--primary);"></i>Nueva Categoría</h1>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert-sghr-danger mb-3">
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
        </div>
    }

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div class="mb-3">
            <label class="form-label-sghr" asp-for="Nombre">Nombre *</label>
            <input asp-for="Nombre" class="form-control-sghr" placeholder="ej. Suite Presidencial" />
            <span asp-validation-for="Nombre" class="field-validation-error"></span>
        </div>
        <div class="mb-3">
            <label class="form-label-sghr" asp-for="Descripcion">Descripción</label>
            <textarea asp-for="Descripcion" class="form-control-sghr" rows="3" placeholder="Descripción de la categoría..."></textarea>
        </div>
        <div class="mb-3">
            <label class="form-label-sghr" asp-for="TarifaPorNoche">Tarifa por noche (USD) *</label>
            <input asp-for="TarifaPorNoche" type="number" step="0.01" min="0.01" class="form-control-sghr" placeholder="0.00" />
            <span asp-validation-for="TarifaPorNoche" class="field-validation-error"></span>
        </div>
        <div class="mb-3">
            <label class="form-label-sghr" asp-for="Caracteristicas">Características</label>
            <input asp-for="Caracteristicas" class="form-control-sghr" placeholder="ej. Vista al mar, jacuzzi, minibar" />
        </div>
        <div class="mb-4 d-flex align-items-center gap-2">
            <input asp-for="Activa" type="checkbox" style="width:18px;height:18px;accent-color:var(--primary);" />
            <label class="form-label-sghr mb-0" asp-for="Activa">Categoría activa</label>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn-primary-sghr"><i class="bi bi-check-lg"></i> Crear Categoría</button>
            <a asp-action="Index" class="btn-ghost">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
